{
  "expo": {
    "name": "CanaBoom",
    "slug": "canaboom-mobile",
    "version": "1.0.0",
    "orientation": "landscape",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#09052d"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.finixai.canaboom"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#09052d"
      },
      "package": "com.finixai.canaboom"
    },
    "plugins": ["expo-asset"]
  }
}
